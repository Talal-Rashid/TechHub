<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <include layout="@layout/layout_top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/phoneSearchBox"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Search model/spec..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterBrand"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="Brand: Samsung, Xiaomi, OnePlus..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterChipset"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="Chipset: Snapdragon, Dimensity..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterDisplay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="Display: AMOLED, OLED, IPS..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterRefreshRate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="Refresh rate: 90Hz, 120Hz, 144Hz..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterRam"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="RAM: 6GB, 8GB, 12GB..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <EditText
                android:id="@+id/filterBattery"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:hint="Battery: 5000, 6000..."
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <CheckBox
                android:id="@+id/checkPtaApproved"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="PTA approved only"
                android:textColor="@color/primary_text" />

            <Button
                android:id="@+id/btnFindPhones"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button_amber"
                android:text="Find Phones"
                android:textColor="@color/black" />

            <LinearLayout
                android:id="@+id/phoneResultsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>