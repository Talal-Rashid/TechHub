<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/layout_top_bar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/emailEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Sub-admin email"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:textColor="@color/primary_text"
                android:textColorHint="@color/secondary_text"
                android:background="@drawable/bg_dashboard_card" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textColor="@color/primary_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp" />

            <CheckBox
                android:id="@+id/checkManageVendors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage vendors"
                android:textColor="@color/primary_text" />

            <CheckBox
                android:id="@+id/checkManageProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage products"
                android:textColor="@color/primary_text" />

            <CheckBox
                android:id="@+id/checkManageOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage orders"
                android:textColor="@color/primary_text" />

            <CheckBox
                android:id="@+id/checkManagePcBuilds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage PC build orders"
                android:textColor="@color/primary_text" />

            <CheckBox
                android:id="@+id/checkManageUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage users"
                android:textColor="@color/primary_text" />

            <CheckBox
                android:id="@+id/checkHideProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hide bad products"
                android:textColor="@color/primary_text" />

            <Button
                android:id="@+id/btnInvite"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_black"
                android:text="Create Invite"
                android:textColor="@color/white" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>